#!/usr/bin/env bash

PASTA_DESTINO="$HOME/Documentos/Convertidos"
mkdir -p "$PASTA_DESTINO"

quantidade=0

while IFS= read -r arquivo; do
    [ -z "$arquivo" ] && continue
    [ ! -f "$arquivo" ] && continue
    [[ "$arquivo" == *.png ]] && continue

    base=$(basename "$arquivo")
    nome_sem_ext="${base%.*}"
    destino="$PASTA_DESTINO/${nome_sem_ext}.png"

    if convert "$arquivo" "$destino"; then
        quantidade=$((quantidade + 1))
    fi
done < <(printf '%s\n' "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS")

if [ "$quantidade" -gt 0 ]; then
    notify-send "Conversão para PNG concluída" \
                "Imagens convertidas salvas em: $PASTA_DESTINO" \
                -u normal
else
    notify-send "Nenhuma imagem convertida para PNG" \
                "Os arquivos selecionados já eram PNG ou não foram suportados." \
                -u normal
fi
