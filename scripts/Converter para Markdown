#!/usr/bin/env bash

PASTA_DESTINO="$HOME/Documentos/Convertidos"
mkdir -p "$PASTA_DESTINO"

quantidade=0

while IFS= read -r arquivo; do
    [ -z "$arquivo" ] && continue
    [ ! -f "$arquivo" ] && continue
    [[ "$arquivo" == *.md || "$arquivo" == *.markdown ]] && continue

    base=$(basename "$arquivo")
    nome_sem_ext="${base%.*}"
    ext="${arquivo##*.}"
    destino="$PASTA_DESTINO/${nome_sem_ext}.md"

    case "$ext" in
        docx|odt|rtf|html|rst|org|txt|tex|latex)
            if pandoc "$arquivo" -o "$destino" -t markdown; then
                quantidade=$((quantidade + 1))
            fi
            ;;
        pdf)
            tmp_txt=$(mktemp)
            if pdftotext "$arquivo" "$tmp_txt" && pandoc "$tmp_txt" -o "$destino" -t markdown; then
                quantidade=$((quantidade + 1))
            fi
            rm -f "$tmp_txt"
            ;;
        *)
            if pandoc "$arquivo" -o "$destino" -t markdown 2>/dev/null; then
                quantidade=$((quantidade + 1))
            fi
            ;;
    esac
done < <(printf '%s\n' "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS")

if [ "$quantidade" -gt 0 ]; then
    notify-send "Conversão para Markdown concluída" \
                "Arquivos convertidos salvos em: $PASTA_DESTINO" \
                -u normal
else
    notify-send "Nenhum arquivo convertido para Markdown" \
                "Os arquivos selecionados já eram Markdown ou não foram suportados." \
                -u normal
fi
