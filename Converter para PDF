#!/usr/bin/env bash

PASTA_DESTINO="$HOME/Documentos/Convertidos"
mkdir -p "$PASTA_DESTINO"

quantidade=0

printf '%s\n' "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS" | while IFS= read -r arquivo; do
    # Ignora se já for PDF
    [[ "$arquivo" == *.pdf ]] && continue

    base=$(basename "$arquivo")
    nome_sem_ext="${base%.*}"
    ext="${arquivo##*.}"
    destino="$PASTA_DESTINO/${nome_sem_ext}.pdf"

    # Formatos de texto/markup: pandoc -> typst -> PDF
    case "$ext" in
        md|markdown|txt|html|rst|org|docx|odt|rtf)
            tmp_typ=$(mktemp --suffix=.typ)
            pandoc "$arquivo" -o "$tmp_typ" -t typst
            typst compile "$tmp_typ" "$destino"
            rm -f "$tmp_typ"
            ;;
        tex|latex)
            typst compile "$arquivo" "$destino" 2>/dev/null || true
            ;;
        *)
            pandoc "$arquivo" -o "$destino" 2>/dev/null || true
            ;;
    esac

    quantidade=$((quantidade + 1))
done

# Notificação final (fora do subshell do while)
if [ "$quantidade" -gt 0 ]; then
    notify-send "Conversão para PDF concluída" \
                "Arquivos convertidos salvos em: $PASTA_DESTINO" \
                -u normal
else
    notify-send "Nenhum arquivo convertido para PDF" \
                "Os arquivos selecionados já eram PDF ou não foram suportados." \
                -u normal
fi
